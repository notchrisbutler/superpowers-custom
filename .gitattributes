# Ensure shell scripts always have LF line endings
*.sh text eol=lf

# Ensure command wrappers keep LF when present
*.cmd text eol=lf

# Common text files
*.md text eol=lf
*.json text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.ts text eol=lf

# Explicitly mark binary files
*.png binary
*.jpg binary
*.gif binary
